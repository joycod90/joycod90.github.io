<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Access Granted</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Montserrat:wght@400;500&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  background: url('bg.jpg') no-repeat center/cover;
  font-family: 'Montserrat', sans-serif;
  color: #F5E6C8;
  overflow: hidden;
}

.overlay {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
}

.container {
  position: relative;
  z-index: 2;
  animation: fadeIn 1.2s ease;
}

h1 {
  font-family: 'Playfair Display', serif;
  letter-spacing: 0.15em;
  font-size: 2.5em;
}

p {
  color: #D6C6A5;
  margin: 10px 0;
}

#countdown {
  margin-top: 20px;
  font-size: 2em;
}

#line {
  width: 200px;
  height: 3px;
  background: rgba(255,255,255,0.2);
  margin: 15px auto;
  position: relative;
  overflow: hidden;
  border-radius: 2px;
}

#leopard {
  position: absolute;
  left: 0;
  top: -18px;
  font-size: 2.2rem; /* 🔥 plus gros */
  transition: transform 0.1s linear;
}

/* animation apparition */
@keyframes fadeIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}
</style>
</head>

<body>

<div class="overlay"></div>

<div class="container">
  <h1>ACCESS GRANTED</h1>

  <p>You have been selected.</p>

  <p>Stand by…</p>

  <div id="line">
    <span id="leopard">🐆</span>
  </div>

  <div id="countdown">7</div>
</div>

<audio id="jingle" src="jingle.mp3" preload="auto"></audio>

<script>
const leopard = document.getElementById("leopard");
const countdownEl = document.getElementById("countdown");
const audio = document.getElementById("jingle");

let position = 0;
let frame = 0;
let timeLeft = 7;

// 🔊 audio avec fallback mobile
document.body.addEventListener("click", () => {
  audio.play().catch(()=>{});
}, { once: true });

setTimeout(() => {
  audio.play().catch(()=>{});
}, 500);

// 🐆 animation 4 frames simulées
setInterval(() => {
  frame++;

  switch(frame % 4) {
    case 0:
      leopard.style.transform = "translateY(0px) scaleX(1)";
      break;
    case 1:
      leopard.style.transform = "translateY(-3px) scaleX(1.05)";
      break;
    case 2:
      leopard.style.transform = "translateY(1px) scaleX(0.95)";
      break;
    case 3:
      leopard.style.transform = "translateY(-2px) scaleX(1.05)";
      break;
  }

}, 120);

// déplacement fluide
setInterval(() => {
  position += 1.5;
  leopard.style.left = position + "px";

  if (position > 180) {
    position = 0;
  }
}, 20);

// countdown
const timer = setInterval(() => {
  timeLeft--;
  countdownEl.textContent = timeLeft;

  if (timeLeft <= 0) {
    clearInterval(timer);
    window.location.href = "TON_LIEN_FINAL";
  }
}, 1000);
</script>

</body>
</html>
